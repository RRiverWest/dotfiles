    }
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "ctrl-delete": [
        "project_panel::Delete",
        {
          "skip_prompt": false
        }
      ]
    }
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "ctrl-backspace": [
        "project_panel::Delete",
        {
          "skip_prompt": false
        }
      ]
    }
  },
  {
    "context": "ProjectPanel",
    "unbind": {
      "shift-delete": [
        "project_panel::Delete",
        {
          "skip_prompt": false
        }
      ]
    }
  },
  {
    "context": "ProjectPanel && not_editing",
